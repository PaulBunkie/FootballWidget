<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widgetRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- The actual background layer with rounded corners -->
    <ImageView
        android:id="@+id/widgetBackground"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/widget_rounded_bg"
        android:scaleType="fitXY" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="4dp"
        android:paddingEnd="4dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp">

        <!-- Home logo (left edge) -->
        <ImageView
            android:id="@+id/homeLogo"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:scaleType="centerInside"
            android:layout_marginStart="8dp" />

        <!-- Prev button (inside home zone) -->
        <LinearLayout
            android:id="@+id/btnPrev"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:background="?android:attr/selectableItemBackground"
            android:orientation="vertical"
            android:paddingEnd="6dp">

            <ImageView
                android:id="@+id/homeStar"
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/ic_star"
                android:visibility="invisible"
                android:layout_marginBottom="2dp" />

            <TextView
                android:id="@+id/homeTeam"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:singleLine="true"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Center (details) -->
        <LinearLayout
            android:id="@+id/btnDetails"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:background="?android:attr/selectableItemBackground"
            android:orientation="vertical"
            android:paddingStart="8dp"
            android:paddingEnd="8dp">

            <TextView
                android:id="@+id/matchScore"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:gravity="center"
                android:visibility="gone" />

            <TextView
                android:id="@+id/matchTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FDD835"
                android:textSize="9sp"
                android:textStyle="bold"
                android:gravity="center" />

            <LinearLayout
                android:id="@+id/oddsContainer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:layout_marginTop="2dp">
                <TextView android:id="@+id/oddsHome" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#4CAF50" android:textSize="11sp" />
                <TextView android:id="@+id/arrow1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text=" → " android:textColor="#80FFFFFF" android:textSize="10sp" android:visibility="gone" />
                <TextView android:id="@+id/oddsAway" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#F44336" android:textSize="11sp" />
                <TextView android:id="@+id/arrow2" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text=" → " android:textColor="#80FFFFFF" android:textSize="10sp" android:visibility="gone" />
                <TextView android:id="@+id/oddsDraw" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#FFFFFF" android:textSize="11sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/dotsContainer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- Next button (inside away zone) -->
        <LinearLayout
            android:id="@+id/btnNext"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:background="?android:attr/selectableItemBackground"
            android:orientation="vertical"
            android:paddingStart="6dp">

            <ImageView
                android:id="@+id/awayStar"
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/ic_star"
                android:visibility="invisible"
                android:layout_marginBottom="2dp" />

            <TextView
                android:id="@+id/awayTeam"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:singleLine="true"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Away logo (right edge) -->
        <ImageView
            android:id="@+id/awayLogo"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:scaleType="centerInside"
            android:layout_marginEnd="8dp" />
    </LinearLayout>
</FrameLayout>